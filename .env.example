# Supabase 项目设置 -> API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend API key 与发件地址（向管理员发送审核通知）
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=AstraOS <onboarding@your-domain.com>
ADMIN_EMAIL=admin@example.com

# Vercel 正式网址，用于生成审核链接
APP_URL=https://http-localhost-3100.vercel.app

# 至少 32 位随机字符串，用于签名管理员审核链接
ADMIN_ACTION_SECRET=replace-with-a-long-random-secret

# 可选：单独设置登录会话密钥；未设置时使用 ADMIN_ACTION_SECRET
AUTH_SESSION_SECRET=replace-with-another-long-random-secret

# Vercel 每日自动扫描验证密钥（至少 16 位随机字符串）
CRON_SECRET=replace-with-a-random-cron-secret

# 可选：逗号分隔的额外前端来源
ALLOWED_ORIGINS=https://your-custom-domain.com

# 可选：静态镜像中的注册按钮跳转到 Vercel 动态站点
NEXT_PUBLIC_REGISTRATION_URL=https://http-localhost-3100.vercel.app/register