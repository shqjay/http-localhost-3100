# Supabase 项目设置 -> API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend API key 与已验证发件地址
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=AstraOS <onboarding@your-domain.com>

# 接收新申请通知的管理员邮箱
ADMIN_EMAIL=admin@example.com

# Vercel 正式网址，用于生成审核链接
APP_URL=https://http-localhost-3100.vercel.app

# 至少 32 位随机字符串，用于签署同意/拒绝链接
ADMIN_ACTION_SECRET=replace-with-a-long-random-secret

# 可选：逗号分隔的额外前端来源
ALLOWED_ORIGINS=https://your-custom-domain.com